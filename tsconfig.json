{
    "include": [
        "ts/**/*.ts",
        "ts/**/*.d.ts"
    ],
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "module": "ES2022",
        "moduleDetection": "force",
        "rootDir": "./ts",
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "outDir": "./js",
        "verbatimModuleSyntax": true
    }
}